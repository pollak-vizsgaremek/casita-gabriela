generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model booking {
  id             Int      @id @default(autoincrement())
  arrival_date   DateTime @db.Date
  departure_date DateTime @db.Date
  people         Int
  booking_date   DateTime @db.DateTime(0)
  status         String   @db.VarChar(50)
  user_id        Int
  room_id        Int
  total_price    Int      @default(0)
  users          users    @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "booking_ibfk_1")
  room           room     @relation(fields: [room_id], references: [id], onUpdate: Restrict, map: "booking_ibfk_2")

  @@index([room_id], map: "room_id")
  @@index([user_id], map: "user_id")
}

model form {
  id           Int      @id @default(autoincrement())
  name         String   @db.Text
  email        String   @db.VarChar(50)
  phone_number String   @db.VarChar(20)
  topic        String   @db.VarChar(50)
  description  String   @db.VarChar(1000)
  created_at   DateTime @default(now()) @db.DateTime(0)
}

model category {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(50)
  image String @db.LongText

  rooms room[] @relation("RoomCategory")
}

model room {
  id             Int    @id @default(autoincrement())
  name           String @db.VarChar(30)
  description    String @db.VarChar(1000)
  price          Int
  ac_availablity Int

  category     Int?
  category_rel category? @relation("RoomCategory", fields: [category], references: [id])

  space         Int
  images        String  @db.LongText
  isHighlighted Boolean @default(false)

  booking     booking[]
  room_review room_review[]
}

model room_review {
  id      Int    @id @default(autoincrement())
  stars   Int
  comment String @db.VarChar(200)
  room_id Int
  user_id Int?
  room    room   @relation(fields: [room_id], references: [id], onUpdate: Restrict, map: "room_review_ibfk_1")
  user    users? @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "room_review_ibfk_2")

  @@index([room_id], map: "booking_id")
  @@index([user_id], map: "user_id")
}

model users {
  id              Int           @id @default(autoincrement())
  name            String        @db.Text
  password        String        @db.VarChar(100)
  phone_number    String        @db.VarChar(20)
  birth_date      DateTime      @db.Date
  address         String        @db.VarChar(50)
  identity_card   String        @db.VarChar(50)
  email           String        @unique(map: "unique_email") @db.VarChar(50)
  isAdmin         Boolean?      @default(false)
  isFirstTimeUser Boolean?      @default(true)
  booking         booking[]
  room_review     room_review[]
}
